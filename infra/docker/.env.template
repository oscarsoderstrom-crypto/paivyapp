# ─────────────────────────────────────────────────────────────────────────────
# Päivy — self-hosted Supabase override values
#
# This is NOT the full Supabase env file. Start from the upstream template:
#     git clone --depth 1 https://github.com/supabase/supabase
#     cp supabase/docker/.env.example supabase/docker/.env
# then set the variables below inside that .env. The upstream file has many more
# keys; these are the ones you MUST change from the insecure defaults plus the
# Päivy-specific config. Generate the secret values with:
#     infra/scripts/generate-secrets.sh
#
# Use DIFFERENT secrets for staging and production. Never commit the filled-in
# values — keep them in a password manager / sops.
#
# NOTE: GoTrue/Supabase env var names are version-sensitive. Confirm each key
# exists in the upstream .env.example for your pinned version.
# ─────────────────────────────────────────────────────────────────────────────

## Secrets — paste from infra/docker/.env.secrets
POSTGRES_PASSWORD=__from_generate_secrets__
JWT_SECRET=__from_generate_secrets__
ANON_KEY=__from_generate_secrets__
SERVICE_ROLE_KEY=__from_generate_secrets__
SECRET_KEY_BASE=__from_generate_secrets__
VAULT_ENC_KEY=__from_generate_secrets__
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=__from_generate_secrets__

## Public URLs — the HTTPS hostname the app and Studio reach (via Cloudflare).
## Use api.staging.paivy.fi on the ThinkStation, api.paivy.fi on Hetzner.
SITE_URL=https://api.staging.paivy.fi
API_EXTERNAL_URL=https://api.staging.paivy.fi
SUPABASE_PUBLIC_URL=https://api.staging.paivy.fi
## Deep-link target so auth emails return to the app (matches app.json "scheme")
ADDITIONAL_REDIRECT_URLS=paivyapp://*

## Auth — signup MUST stay enabled at the GoTrue level; the invite gating is
## enforced by the handle_new_user() trigger, not by disabling signup.
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=false
## Staging convenience: auto-confirm emails so you don't need SMTP to test.
## Set this to false in PRODUCTION and configure SMTP below.
ENABLE_EMAIL_AUTOCONFIRM=true

## SMTP — REQUIRED in production for password reset & email confirmation.
SMTP_ADMIN_EMAIL=admin@paivy.fi
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=__smtp_user__
SMTP_PASS=__smtp_pass__
SMTP_SENDER_NAME=Päivy

## Studio — keep behind Cloudflare Access / Tailscale; never expose publicly.
STUDIO_DEFAULT_ORGANIZATION=Paivy
STUDIO_DEFAULT_PROJECT=Paivy
