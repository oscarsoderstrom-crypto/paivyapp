# Supabase project credentials.
#
# These are EXPO_PUBLIC_* values, so they are bundled into the app and are
# visible to anyone who installs it. That is expected: the anon key is a
# public client key whose access is constrained entirely by Row Level
# Security in the database. NEVER put the service_role key (or any other
# server-side secret) in an EXPO_PUBLIC_* variable.
#
# Copy this file to `.env` and fill in the values from your Supabase
# dashboard → Project Settings → API. `.env` is git-ignored.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
